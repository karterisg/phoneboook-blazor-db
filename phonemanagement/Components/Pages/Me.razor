@page "/me"
@rendermode InteractiveServer
@implements IDisposable

@using phonemanagement.Dtos.Me
@inject ApiClient Api
@inject ClientAuthState Auth
@inject NavigationManager Nav

<PageTitle>My Profile</PageTitle>

@if (!authReady)
{
    <p class="text-muted">Loading…</p>
}
else if (!Auth.IsLoggedIn)
{
    <div class="alert alert-warning">
        You must be logged in.
        <a class="btn btn-sm btn-primary ms-2" href="/login">Login</a>
    </div>
}
else if (Auth.IsAdmin)
{
    <div class="alert alert-info">
        Admin accounts manage tasks. Redirecting…
    </div>
}
else if (loading)
{
    <p class="text-muted">Loading…</p>
}
else if (me is null || model is null)
{
    <div class="alert alert-danger">Profile not found.</div>
}
else
{
    <div class="pb-page-header">
        <p class="pb-kicker">Account</p>
        <h1>My profile</h1>
        <p class="text-muted mb-0">Update your details and password.</p>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-7">
            <div class="pb-card">
                <div class="pb-card-body">
                    <h3 class="h5 mb-3">Details</h3>

                    <EditForm Model="model" OnValidSubmit="SaveAsync" FormName="me-update-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-2">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Name</label>
                                <InputText class="form-control" @bind-Value="model.Name" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Phone</label>
                                <InputText class="form-control" @bind-Value="model.Phone" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Gender</label>
                                <InputSelect class="form-control" @bind-Value="model.Gender">
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </InputSelect>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Email</label>
                                <InputText class="form-control" @bind-Value="model.Email" />
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(error))
                        {
                            <div class="alert alert-danger mt-3 mb-0">@error</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(success))
                        {
                            <div class="alert alert-success mt-3 mb-0">@success</div>
                        }

                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-primary" disabled="@busy">Save</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@busy">Reset</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <div class="pb-card">
                <div class="pb-card-body">
                    <h3 class="h5 mb-3">Change password</h3>

                    <EditForm Model="pwd" OnValidSubmit="ChangePasswordAsync" FormName="me-password-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-2">
                            <label class="form-label">Current password</label>
                            <InputText class="form-control" type="password" @bind-Value="pwd.CurrentPassword" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">New password</label>
                            <InputText class="form-control" type="password" @bind-Value="pwd.NewPassword" />
                            <div class="form-text">Min 6 characters.</div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(pwdError))
                        {
                            <div class="alert alert-danger mb-0">@pwdError</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(pwdSuccess))
                        {
                            <div class="alert alert-success mb-0">@pwdSuccess</div>
                        }

                        <button class="btn btn-success mt-3" disabled="@busy">Update password</button>
                    </EditForm>
                </div>
            </div>

            <div class="mt-3 text-muted small">
                Role: <span class="badge text-bg-secondary">@me.Role</span>
            </div>
        </div>
    </div>
}

@code {
    private bool authReady;
    private bool loading = true;
    private bool busy;

    private string? error;
    private string? success;

    private string? pwdError;
    private string? pwdSuccess;

    private MeResponse? me;
    private MeUpdateRequest? model;
    private ChangePasswordRequest pwd = new();

    protected override Task OnInitializedAsync()
    {
        Auth.Changed += OnAuthChanged;
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Auth.LoadAsync();
        authReady = true;

        if (!Auth.IsLoggedIn)
        {
            loading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (Auth.IsAdmin)
        {
            Nav.NavigateTo("/tasks");
            return;
        }

        await ReloadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAuthChanged()
    {
        if (!authReady)
            return;

        if (!Auth.IsLoggedIn)
        {
            me = null;
            model = null;
            loading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await ReloadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAsync()
    {
        loading = true;
        error = null;
        success = null;
        pwdError = null;
        pwdSuccess = null;

        try
        {
            var res = await Api.GetAsync<MeResponse>("/api/me");
            me = res;
            model = res is null
                ? null
                : new MeUpdateRequest
                {
                    Name = res.Name,
                    Phone = res.Phone,
                    Gender = res.Gender,
                    Email = res.Email
                };
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (model is null)
            return;

        busy = true;
        error = null;
        success = null;
        try
        {
            var updated = await Api.PutAsync<MeUpdateRequest, MeResponse>("/api/me", model);
            if (updated is null)
            {
                error = Api.LastError ?? "Save failed.";
                return;
            }

            me = updated;
            success = "Saved.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        busy = true;
        pwdError = null;
        pwdSuccess = null;
        try
        {
            var res = await Api.PutAsync<ChangePasswordRequest, object>("/api/me/password", pwd);
            if (res is null)
            {
                pwdError = Api.LastError ?? "Password update failed.";
                return;
            }

            pwd = new ChangePasswordRequest();
            pwdSuccess = "Password updated.";
        }
        finally
        {
            busy = false;
        }
    }

    public void Dispose()
    {
        Auth.Changed -= OnAuthChanged;
    }
}

