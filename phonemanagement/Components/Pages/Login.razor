@page "/login"
@rendermode InteractiveServer

@using phonemanagement.Dtos.Auth
@inject ApiClient Api
@inject ClientAuthState Auth
@inject NavigationManager Nav

<PageTitle>Login</PageTitle>

<h3>Login</h3>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="mb-3">
    <label class="form-label">Email</label>
    <input class="form-control" @bind="model.Email" />
</div>

<div class="mb-3">
    <label class="form-label">Password</label>
    <input type="password" class="form-control" @bind="model.Password" />
</div>


<div class="mb-3">
    <label class="form-label">Go to after login</label>
    <select class="form-select" @bind="redirectTo">
        <option value="/contacts">Contacts</option>
        <option value="/tasks">Tasks</option>
        <option value="/me">My Profile</option>
    </select>
</div>

<button class="btn btn-success"
        disabled="@busy"
        @onclick="LoginAsync">
    @(busy ? "Logging in..." : "Login")
</button>

@code {
    private LoginRequest model = new();
    private bool busy;
    private string? error;

  
    private string redirectTo = "/contacts";

    private async Task LoginAsync()
    {
        busy = true;
        error = null;

        try
        {
            var res = await Api.PostAsync<LoginRequest, AuthResponse>("/api/auth/login", model);

            if (res is null)
            {
                error = "Η σύνδεση απέτυχε. Ελέγξτε τα στοιχεία σας.";
                return;
            }

            await Auth.SetAccessTokenAsync(res.AccessToken);

            Nav.NavigateTo(redirectTo);
        }
        finally
        {
            busy = false;
        }
    }
}