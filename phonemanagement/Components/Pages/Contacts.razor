@page "/contacts"
@inject NavigationManager Nav
@inject phonemanagement.Services.ApiClient Api
@inject phonemanagement.Services.ClientAuthState Auth
@rendermode InteractiveServer
@using phonemanagement.Dtos.Directory

<h3>Phone Directory</h3>

@if (!authReady)
{
    <p class="text-muted">Loading…</p>
    return;
}

<div class="mb-3">
    <button class="btn btn-primary me-2" @onclick="Search">Search</button>
    <button class="btn btn-secondary me-2" @onclick="ClearSearch">Clear</button>
    <button class="btn btn-info me-2" @onclick="Refresh">Refresh</button>
    @if (canEdit)
    {
        <a class="btn btn-success me-2" href="/add-user">Add Contact</a>
        <a class="btn btn-outline-dark" href="/users">Manage users</a>
    }
</div>

<input class="form-control mb-2"
       placeholder="Search by name, phone, or email..."
       @bind="SearchText"
       @bind:event="oninput" />

<div class="mb-3">
    <button class="btn btn-outline-dark me-2" @onclick="() => ToggleSort(SortField.Name)">
        Name @SortIndicator(SortField.Name)
    </button>

    <button class="btn btn-outline-dark me-2" @onclick="() => ToggleSort(SortField.Phone)">
        Phone @SortIndicator(SortField.Phone)
    </button>

    <button class="btn btn-outline-dark me-2" @onclick="() => ToggleSort(SortField.Gender)">
        Gender @SortIndicator(SortField.Gender)
    </button>

    <button class="btn btn-outline-dark me-2" @onclick="() => ToggleSort(SortField.Email)">
        Email @SortIndicator(SortField.Email)
    </button>

    <button class="btn btn-warning me-2" @onclick="ClearSort">Clear Sort</button>
</div>

<ul class="list-group">
    @foreach (var contact in contacts)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <span style="color:@(contact.Gender == "Female" ? "red" : "green"); font-weight:bold;">
                -
            </span>

            <span>
                @contact.Name - @contact.Phone (@contact.Email)
            </span>

            <span class="d-flex gap-2">
                <a class="btn btn-sm btn-outline-info" href="@($"/contact/{contact.Id}")">View</a>

                @if (canEdit)
                {
                    <a class="btn btn-sm btn-warning" href="@($"/edit-user/{contact.Id}")">Edit</a>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteUserAsync(contact.Id)" disabled="@busy">Delete</button>
                }
            </span>
        </li>
    }
</ul>

@if (!contacts.Any())
{
    <p class="text-danger mt-2">No contacts found.</p>
}

<div class="mt-3">

    @* Import removed: data comes from SQL Server *@
</div>

@code {
    private List<DirectoryContactResponse> contacts = new();
    private string searchText = "";
    private bool canEdit;
    private bool authReady;
    private bool busy;

    private SortField? sortField = null;
    private SortDirection sortDirection = SortDirection.Asc;

    string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            _ = Search();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Auth.LoadAsync();
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        canEdit = Auth.IsAdmin;

        // Support deep link from Home quick search: /contacts?search=...
        var uri = new Uri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("search", out var q) && !string.IsNullOrWhiteSpace(q))
        {
            searchText = q.ToString();
        }

        contacts = await LoadDirectoryAsync();
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            await Search();
        }

        authReady = true;
        await InvokeAsync(StateHasChanged);
    }






    async Task Search()
    {
        var all = await LoadDirectoryAsync();
        if (string.IsNullOrWhiteSpace(searchText))
        {
            contacts = all;
        }
        else
        {
            var q = searchText.Trim();
            contacts = all.Where(c =>
                    (c.Name?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.Phone?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.Email?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false))
                .ToList();
        }

        ApplySort();
    }

    async Task ClearSearch()
    {
        searchText = "";
        await Refresh();
    }

    void ToggleSort(SortField field)
    {
        if (sortField == field)
        {
            sortDirection = sortDirection == SortDirection.Asc ? SortDirection.Desc : SortDirection.Asc;
        }
        else
        {
            sortField = field;
            sortDirection = SortDirection.Asc;
        }
        ApplySort();
    }

    string SortIndicator(SortField field)
    {
        if (sortField != field) return "";
        return sortDirection == SortDirection.Asc ? "↑" : "↓";
    }

    void ApplySort()
    {
        if (sortField is null) return;

        contacts = (sortField.Value, sortDirection) switch
        {
            (SortField.Name, SortDirection.Asc) => contacts.OrderBy(c => c.Name).ToList(),
            (SortField.Name, SortDirection.Desc) => contacts.OrderByDescending(c => c.Name).ToList(),

            (SortField.Phone, SortDirection.Asc) => contacts.OrderBy(c => c.Phone).ToList(),
            (SortField.Phone, SortDirection.Desc) => contacts.OrderByDescending(c => c.Phone).ToList(),

            (SortField.Gender, SortDirection.Asc) => contacts.OrderBy(c => c.Gender).ToList(),
            (SortField.Gender, SortDirection.Desc) => contacts.OrderByDescending(c => c.Gender).ToList(),

            (SortField.Email, SortDirection.Asc) => contacts.OrderBy(c => c.Email).ToList(),
            (SortField.Email, SortDirection.Desc) => contacts.OrderByDescending(c => c.Email).ToList(),

            _ => contacts
        };
    }

    void ClearSort()
    {
        sortField = null;
        sortDirection = SortDirection.Asc;
        _ = Refresh();
    }

    async Task Refresh()
    {
        contacts = await LoadDirectoryAsync();
        ApplySort();
    }

    private async Task DeleteUserAsync(Guid id)
    {
        if (!canEdit) return;
        busy = true;
        try
        {
            await Api.DeleteAsync($"/api/users/{id}");
            await Refresh();
        }
        finally
        {
            busy = false;
        }
    }

    private async Task<List<DirectoryContactResponse>> LoadDirectoryAsync()
    {
        var res = await Api.GetAsync<List<DirectoryContactResponse>>("/api/directory");
        return res ?? new();
    }

    enum SortField
    {
        Name,
        Phone,
        Gender,
        Email
    }

    enum SortDirection
    {
        Asc,
        Desc
    }
}