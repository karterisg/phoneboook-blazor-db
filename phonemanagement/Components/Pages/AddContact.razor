@page "/add-contact"
@using PhoneBookApp.Models
@inject NavigationManager Nav
@inject phonemanagement.Services.ApiClient Api
@inject phonemanagement.Services.ClientAuthState Auth
@rendermode InteractiveServer

<PageTitle>Νέα επαφή</PageTitle>

@if (!authReady)
{
    <p class="text-muted">Φόρτωση…</p>
    return;
}

<div class="pb-page-header">
    <p class="pb-kicker">Νέα</p>
    <h1>Κοινή επαφή καταλόγου</h1>
    <p class="text-muted mb-0">Η εγγραφή εμφανίζεται στον κατάλογο για όλους τους συνδεδεμένους χρήστες.</p>
</div>

<div class="pb-card pb-form-card">
    <div class="pb-card-body">
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }
        <EditForm Model="contact" OnValidSubmit="Save">
            <div class="mb-3">
                <label class="form-label">Όνομα</label>
                <InputText @bind-Value="contact.Name" class="form-control" placeholder="π.χ. Γιώργος Παπαδόπουλος" />
            </div>
            <div class="mb-3">
                <label class="form-label">Τηλέφωνο</label>
                <InputText @bind-Value="contact.Phone" class="form-control" placeholder="π.χ. 6912345678" inputmode="tel" />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" placeholder="name@@example.com" @bind="contact.Email" @bind:event="oninput" />
            </div>
            <div class="mb-4">
                <label class="form-label">Φύλο</label>
                <InputSelect @bind-Value="contact.Gender" class="form-select">
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                </InputSelect>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" type="submit" disabled="@busy">
                    <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Αποθήκευση
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">Άκυρο</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    Contact contact = new Contact { Gender = "Male" };
    private bool authReady;
    private bool busy;
    private string? error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Auth.LoadAsync();
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        authReady = true;
        await InvokeAsync(StateHasChanged);
    }

    async Task Save()
    {
        busy = true;
        error = null;
        try
        {
            var created = await Api.PostAsync<Contact, Contact>("/api/contacts", contact);
            if (created is null)
            {
                error = string.IsNullOrWhiteSpace(Api.LastError) ? "Η αποθήκευση απέτυχε." : Api.LastError;
                return;
            }

            Nav.NavigateTo("/contacts");
        }
        finally
        {
            busy = false;
        }
    }

    void GoBack() => Nav.NavigateTo("/contacts");
}
