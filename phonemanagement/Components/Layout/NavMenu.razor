@* NavMenu.razor *@
@inject phonemanagement.Services.ClientAuthState Auth
@inject NavigationManager Nav
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid d-flex flex-column align-items-start gap-0">
        <a class="navbar-brand mb-0" href="" title="Phonebook">Phonebook</a>
        <div class="navbar-sub text-white-50 small">Contacts &amp; directory</div>
        <button class="navbar-toggler" @onclick="ToggleMenu" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="nav-scrollable @(menuOpen ? "open" : "closed")">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (Auth.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="contacts" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-people-fill" aria-hidden="true"></span> Contacts
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="tasks" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-check2-square" aria-hidden="true"></span> Tasks
                </NavLink>
            </div>

            @if (Auth.IsAdmin)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users" Match="NavLinkMatch.Prefix">
                        <span class="bi bi-person-badge" aria-hidden="true"></span> Users
                    </NavLink>
                </div>
            }
        }

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="login" Match="NavLinkMatch.Prefix">
                <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Login
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="register" Match="NavLinkMatch.Prefix">
                <span class="bi bi-person-plus" aria-hidden="true"></span> Register
            </NavLink>
        </div>

        @if (Auth.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <button class="nav-link btn btn-link text-start w-100" @onclick="LogoutAsync">
                    <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Logout
                </button>
            </div>
        }


        <div class="nav-item px-3">
            <NavLink class="nav-link" href="about" Match="NavLinkMatch.Prefix">
                <span class="bi bi-info-circle-fill" aria-hidden="true"></span> About
            </NavLink>
        </div>
    </nav>

</div>

@code {
    private bool menuOpen = false;

    private void ToggleMenu()
    {
        menuOpen = !menuOpen;
    }

    private async Task LogoutAsync()
    {
        await Auth.SetAccessTokenAsync(null);
        Nav.NavigateTo("/login");
    }
}