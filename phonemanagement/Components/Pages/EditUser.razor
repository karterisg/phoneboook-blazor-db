@page "/edit-user/{Id:guid}"
@rendermode InteractiveServer

@using phonemanagement.Dtos.Directory
@using phonemanagement.Dtos.Users
@inject ApiClient Api
@inject ClientAuthState Auth
@inject NavigationManager Nav

<PageTitle>Edit User</PageTitle>

@if (!authReady)
{
    <p class="text-muted">Loading…</p>
}
else if (!Auth.IsLoggedIn)
{
    <div class="alert alert-warning">
        You must be logged in.
        <a class="btn btn-sm btn-primary ms-2" href="/login">Login</a>
    </div>
}
else if (!Auth.IsAdmin)
{
    <div class="alert alert-danger">Admin only.</div>
}
else if (loading)
{
    <p class="text-muted">Loading…</p>
}
else if (model is null)
{
    <div class="alert alert-danger">User not found.</div>
}
else
{
    <h3>Edit contact</h3>

    <EditForm Model="model" OnValidSubmit="SaveAsync" FormName="edit-user-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText class="form-control" @bind-Value="model.Name" />
        </div>
        <div class="mb-3">
            <label class="form-label">Phone</label>
            <InputText class="form-control" @bind-Value="model.Phone" />
        </div>
        <div class="mb-3">
            <label class="form-label">Gender</label>
            <InputSelect class="form-control" @bind-Value="model.Gender">
                <option value="Male">Male</option>
                <option value="Female">Female</option>
            </InputSelect>
        </div>
        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="model.Email" />
        </div>
        <div class="mb-3">
            <label class="form-label">Reset password (optional)</label>
            <InputText class="form-control" type="password" @bind-Value="model.NewPassword" />
            <div class="form-text">Leave empty to keep existing password.</div>
        </div>




        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        <div class="d-flex gap-2">
            <button class="btn btn-success" disabled="@busy">Save</button>
            <a class="btn btn-outline-secondary" href="/contacts">Cancel</a>
        </div>
    </EditForm>

}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool authReady;
    private bool loading = true;
    private bool busy;
    private string? error;
    private AdminUpdateUserRequest? model;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.LoadAsync();
        authReady = true;

        if (!Auth.IsLoggedIn || !Auth.IsAdmin)
        {
            loading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var u = await Api.GetAsync<DirectoryContactResponse>($"/api/users/{Id}");
        model = u is null
            ? null
            : new AdminUpdateUserRequest { Name = u.Name, Phone = u.Phone, Gender = u.Gender, Email = u.Email };

        loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveAsync()
    {
        if (model is null) return;
        busy = true;
        error = null;
        try
        {
            var res = await Api.PutAsync<AdminUpdateUserRequest, DirectoryContactResponse>($"/api/users/{Id}", model);
            if (res is null)
            {
                error = "Save failed.";
                return;
            }

            Nav.NavigateTo("/contacts");
        }
        finally
        {
            busy = false;
        }
    }
}

