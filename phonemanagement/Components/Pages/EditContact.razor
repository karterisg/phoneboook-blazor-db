@page "/edit-contact/{Id:int}"
@using PhoneBookApp.Models
@inject NavigationManager Nav
@inject phonemanagement.Services.IContactsStore Store
@inject phonemanagement.Services.ClientAuthState Auth
@rendermode InteractiveServer

<PageTitle>Επεξεργασία επαφής</PageTitle>

@if (!authReady)
{
    <p class="text-muted">Φόρτωση…</p>
}
else if (contact != null)
{
    <div class="pb-page-header">
        <p class="pb-kicker">Επεξεργασία</p>
        <h1>Επαφή: @contact.Name</h1>
        <p class="text-muted mb-0">Ενημερώστε τα πεδία και αποθηκεύστε.</p>
    </div>

    <div class="pb-card pb-form-card">
        <div class="pb-card-body">
            <EditForm Model="contact" OnValidSubmit="Update">
                <div class="mb-3">
                    <label class="form-label">Όνομα</label>
                    <InputText @bind-Value="contact.Name" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Τηλέφωνο</label>
                    <InputText @bind-Value="contact.Phone" class="form-control" inputmode="tel" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" @bind="contact.Email" @bind:event="oninput" />
                </div>
                <div class="mb-4">
                    <label class="form-label">Φύλο</label>
                    <InputSelect @bind-Value="contact.Gender" class="form-select">
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </InputSelect>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-primary" type="submit">
                        <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Αποθήκευση
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">Άκυρο</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    Contact? contact;
    private bool authReady;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Auth.LoadAsync();
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }
        if (!Auth.IsAdmin)
        {
            Nav.NavigateTo("/contacts");
            return;
        }

        contact = await Store.GetByIdAsync(Id);
        authReady = true;
        await InvokeAsync(StateHasChanged);
    }

    async Task Update()
    {
        if (!Auth.IsAdmin)
            return;

        if (contact != null)
        {
            await Store.UpdateAsync(contact);
            Nav.NavigateTo("/contacts");
        }
    }

    void GoBack() => Nav.NavigateTo("/contacts");
}
