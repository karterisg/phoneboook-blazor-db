{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "phonemanagement",
    "Audience": "phonemanagement",
    "SigningKey": "DEV_LOCAL_signing_key_use_32_chars_minimum_change_in_prod",
