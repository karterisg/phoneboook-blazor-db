@page "/contacts"
@using PhoneBookApp.Models
@rendermode InteractiveServer

<h3>Phone Directory</h3>

<a class="btn btn-success mb-3" href="/add-contact">Add Contact</a>

<ul>
    @foreach (var contact in contacts)
    {
        <li>
            <span style="color:@(contact.Gender == "Female" ? "red" : "green"); font-weight:bold;">
                -
            </span>
            @contact.Name - @contact.Phone

            <a class="btn btn-sm btn-warning me-2" href="/edit-contact/@contact.Id">Edit</a>
            <button class="btn btn-sm btn-danger" @onclick="() => Delete(contact.Id)">
                Delete
            </button>
        </li>
    }
</ul>

@code {
    private List<Contact> contacts = new();

    protected override void OnInitialized()
    {
        contacts = ContactsRepository.GetContacts();
    }

    void Delete(int id)
    {
        ContactsRepository.DeleteContact(id);
        contacts = ContactsRepository.GetContacts();
    }
}