@page "/contacts"
@using PhoneBookApp.Models
@inject NavigationManager Nav
@inject phonemanagement.Services.IContactsStore Store
@rendermode InteractiveServer

<h3>Phone Directory</h3>

<div class="mb-3">
    <button class="btn btn-success me-2" @onclick="Add">Add Contact</button>
    <button class="btn btn-primary me-2" @onclick="Search">Search</button>
    <button class="btn btn-secondary me-2" @onclick="ClearSearch">Clear</button>
    <button class="btn btn-info me-2" @onclick="Refresh">Refresh</button>
</div>

<input class="form-control mb-2"
       placeholder="Search by name and phone..."
       @bind="SearchText"
       @bind:event="oninput" />

<div class="mb-3">
    <button class="btn btn-outline-dark me-2" @onclick="SortByName">Name ↑</button>
    <button class="btn btn-outline-dark me-2" @onclick="SortByNameDesc">Name ↓</button>

    <button class="btn btn-outline-dark me-2" @onclick="SortByPhone">Phone ↑</button>
    <button class="btn btn-outline-dark me-2" @onclick="SortByPhoneDesc">Phone ↓</button>

    <button class="btn btn-outline-dark me-2" @onclick="SortByGender">Gender ↑</button>
    <button class="btn btn-outline-dark me-2" @onclick="SortByGenderDesc">Gender ↓</button>

    <button class="btn btn-outline-dark me-2" @onclick="SortById">Id ↑</button>
    <button class="btn btn-outline-dark me-2" @onclick="SortByIdDesc">Id ↓</button>

    <button class="btn btn-warning me-2" @onclick="ClearSort">Clear Sort</button>
</div>

<ul class="list-group">
    @foreach (var contact in contacts)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <span style="color:@(contact.Gender == "Female" ? "red" : "green"); font-weight:bold;">
                -
            </span>

            <span>
                @contact.Name - @contact.Phone
            </span>

            <span>
                <button class="btn btn-sm btn-warning me-2" @onclick="() => Edit(contact.Id)">
                    Edit
                </button>

                <button class="btn btn-sm btn-danger me-2" @onclick="() => Delete(contact.Id)">
                    Delete
                </button>

                <button class="btn btn-sm btn-info" @onclick="() => View(contact.Id)">
                    View
                </button>
            </span>
        </li>
    }
</ul>

@if (!contacts.Any())
{
    <p class="text-danger mt-2">No contacts found.</p>
}

<div class="mt-3">

    @* Import removed: data comes from SQL Server *@
</div>

@code {
    private List<Contact> contacts = new();
    private string searchText = "";

    string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            Search();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        contacts = await Store.GetAllAsync();
    }

    async Task Delete(int id)
    {
        await Store.DeleteAsync(id);
        await Refresh();
    }

    void Edit(int id)
    {
        Nav.NavigateTo($"/edit-contact/{id}");
    }

    void Add()
    {
        Nav.NavigateTo("/add-contact");
    }

    void View(int id)
    {
        Nav.NavigateTo($"/view-contact/{id}");
    }






    async Task Search()
    {
        contacts = string.IsNullOrWhiteSpace(searchText)
            ? await Store.GetAllAsync()
            : await Store.SearchAsync(searchText);
    }

    async Task ClearSearch()
    {
        searchText = "";
        await Refresh();
    }

    void SortByName() => contacts = contacts.OrderBy(c => c.Name).ToList();
    void SortByPhone() => contacts = contacts.OrderBy(c => c.Phone).ToList();
    void SortByGender() => contacts = contacts.OrderBy(c => c.Gender).ToList();
    void SortById() => contacts = contacts.OrderBy(c => c.Id).ToList();

    void SortByNameDesc() => contacts = contacts.OrderByDescending(c => c.Name).ToList();
    void SortByPhoneDesc() => contacts = contacts.OrderByDescending(c => c.Phone).ToList();
    void SortByGenderDesc() => contacts = contacts.OrderByDescending(c => c.Gender).ToList();
    void SortByIdDesc() => contacts = contacts.OrderByDescending(c => c.Id).ToList();

    void ClearSort() => Refresh();

    async Task Refresh()
    {
        contacts = await Store.GetAllAsync();
    }
}