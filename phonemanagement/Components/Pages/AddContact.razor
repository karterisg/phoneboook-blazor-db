@page "/add-contact"
@using PhoneBookApp.Models

<h3>Add Contact</h3>

<form method="post">

    <InpuText @bind-Value="Name"></InpuText>
    <InpuText @bind-Value="Phone"></InpuText>
  

    <form method="post" action="/add-contact" style="display:inline;">
        <input type="hidden" name="id" value="@contact.Id" />
        <button class="btn btn-sm btn-danger" type="submit">Add Contact</button>
    </form>

</form>

@code {

    Contact contact = new Contact();

    void Save()
    {
        ContactsRepository.AddContact(contact);
        
    }
}