@page "/contacts"
@inject NavigationManager Nav
@inject phonemanagement.Services.ApiClient Api
@inject phonemanagement.Services.ClientAuthState Auth
@rendermode InteractiveServer
@using phonemanagement.Dtos.Directory

<PageTitle>Κατάλογος επαφών</PageTitle>

@if (!authReady)
{
    <div class="d-flex align-items-center gap-2 text-muted py-5">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Φόρτωση…</span>
    </div>
    return;
}

<div class="pb-page-header">
    <p class="pb-kicker">Directory</p>
    <h1>Κατάλογος επαφών</h1>
    <p class="text-muted mb-0">Αναζήτηση, ταξινόμηση και ενέργειες σε κάθε εγγραφή.</p>
</div>

<div class="pb-toolbar">
    <div class="input-group flex-grow-1" style="max-width: 28rem; min-width: 12rem;">
        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
        <input class="form-control border-start-0"
               placeholder="Όνομα, τηλέφωνο ή email…"
               @bind="SearchText"
               @bind:event="oninput" />
    </div>
    <div class="btn-group" role="group">
        <button type="button" class="btn btn-outline-secondary" @onclick="Search"><i class="bi bi-funnel me-1"></i>Φίλτρο</button>
        <button type="button" class="btn btn-outline-secondary" @onclick="ClearSearch">Καθαρισμός</button>
        <button type="button" class="btn btn-primary" @onclick="Refresh"><i class="bi bi-arrow-clockwise me-1"></i>Ανανέωση</button>
    </div>
    <a class="btn btn-success" href="/add-contact"><i class="bi bi-journal-plus me-1"></i>Νέα κοινή επαφή</a>
    @if (canEdit)
    {
        <a class="btn btn-outline-success" href="/add-user"><i class="bi bi-person-plus me-1"></i>Νέος χρήστης</a>
        <a class="btn btn-outline-dark" href="/users"><i class="bi bi-people me-1"></i>Χρήστες</a>
    }
</div>

<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
    <span class="small text-muted me-1">Στήλες:</span>
    <div class="btn-group btn-group-sm flex-wrap" role="group">
        <button type="button" class="btn btn-light border" @onclick="() => ToggleSort(SortField.Name)">Όνομα @SortIndicator(SortField.Name)</button>
        <button type="button" class="btn btn-light border" @onclick="() => ToggleSort(SortField.Phone)">Τηλ. @SortIndicator(SortField.Phone)</button>
        <button type="button" class="btn btn-light border" @onclick="() => ToggleSort(SortField.Gender)">Φύλο @SortIndicator(SortField.Gender)</button>
        <button type="button" class="btn btn-light border" @onclick="() => ToggleSort(SortField.Email)">Email @SortIndicator(SortField.Email)</button>
    </div>
    <button type="button" class="btn btn-sm btn-outline-warning" @onclick="ClearSort">Χωρίς ταξινόμηση</button>
</div>

@if (contacts.Any())
{
    <div class="table-responsive pb-card">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="ps-3">Επαφή</th>
                    <th scope="col">Τηλέφωνο</th>
                    <th scope="col">Email</th>
                    <th scope="col">Φύλο</th>
                    <th scope="col" class="text-end pe-3" style="min-width: 9rem;">Ενέργειες</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var contact in contacts)
            {
                <tr>
                    <td class="ps-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="pb-avatar" style="width:2.25rem;height:2.25rem;font-size:0.85rem;">@GetInitial(contact.Name)</div>
                            <span class="fw-semibold">@contact.Name</span>
                        </div>
                    </td>
                    <td class="text-nowrap">@contact.Phone</td>
                    <td><span class="text-break">@contact.Email</span></td>
                    <td>
                        <span class="pb-gender-pill @GenderPillClass(contact.Gender)">@contact.Gender</span>
                    </td>
                    <td class="text-end pe-3">
                        <a class="btn btn-sm btn-outline-primary" href="@ViewHref(contact)">Προβολή</a>
                        @if (canEdit)
                        {
                            @if (contact.SharedContactId is int scid)
                            {
                                <a class="btn btn-sm btn-outline-secondary" href="@($"/edit-contact/{scid}")">Επεξεργασία</a>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSharedContactAsync(scid)" disabled="@busy">Διαγραφή</button>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-outline-secondary" href="@($"/edit-user/{contact.Id}")">Επεξεργασία</a>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUserAsync(contact.Id)" disabled="@busy">Διαγραφή</button>
                            }
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="pb-empty">
        <i class="bi bi-person-lines-fill"></i>
        <p class="mb-0 fw-medium">Δεν βρέθηκαν εγγραφές.</p>
        <p class="small mt-1 mb-0">Δοκιμάστε άλλα κριτήρια αναζήτησης.</p>
    </div>
}

@code {
    private List<DirectoryContactResponse> contacts = new();
    private string searchText = "";
    private bool canEdit;
    private bool authReady;
    private bool busy;

    private SortField? sortField = null;
    private SortDirection sortDirection = SortDirection.Asc;

    string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            _ = Search();
        }
    }

    private static string GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var t = name.Trim();
        return t.Length == 0 ? "?" : char.ToUpper(t[0]).ToString();
    }

    private static string GenderPillClass(string? gender) =>
        string.Equals(gender, "Female", StringComparison.OrdinalIgnoreCase) ? "pb-gender-pill--f" : "pb-gender-pill--m";

    private static string ViewHref(DirectoryContactResponse c) =>
        c.SharedContactId is not null ? $"/view-contact/{c.SharedContactId}" : $"/contact/{c.Id}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Auth.LoadAsync();
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        canEdit = Auth.IsAdmin;

        var uri = new Uri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("search", out var q) && !string.IsNullOrWhiteSpace(q))
        {
            searchText = q.ToString();
        }

        contacts = await LoadDirectoryAsync();
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            await Search();
        }

        authReady = true;
        await InvokeAsync(StateHasChanged);
    }

    async Task Search()
    {
        var all = await LoadDirectoryAsync();
        if (string.IsNullOrWhiteSpace(searchText))
        {
            contacts = all;
        }
        else
        {
            var qv = searchText.Trim();
            contacts = all.Where(c =>
                    (c.Name?.Contains(qv, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.Phone?.Contains(qv, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.Email?.Contains(qv, StringComparison.OrdinalIgnoreCase) ?? false))
                .ToList();
        }

        ApplySort();
    }

    async Task ClearSearch()
    {
        searchText = "";
        await Refresh();
    }

    void ToggleSort(SortField field)
    {
        if (sortField == field)
        {
            sortDirection = sortDirection == SortDirection.Asc ? SortDirection.Desc : SortDirection.Asc;
        }
        else
        {
            sortField = field;
            sortDirection = SortDirection.Asc;
        }
        ApplySort();
    }

    string SortIndicator(SortField field)
    {
        if (sortField != field) return "";
        return sortDirection == SortDirection.Asc ? "↑" : "↓";
    }

    void ApplySort()
    {
        if (sortField is null) return;

        contacts = (sortField.Value, sortDirection) switch
        {
            (SortField.Name, SortDirection.Asc) => contacts.OrderBy(c => c.Name).ToList(),
            (SortField.Name, SortDirection.Desc) => contacts.OrderByDescending(c => c.Name).ToList(),

            (SortField.Phone, SortDirection.Asc) => contacts.OrderBy(c => c.Phone).ToList(),
            (SortField.Phone, SortDirection.Desc) => contacts.OrderByDescending(c => c.Phone).ToList(),

            (SortField.Gender, SortDirection.Asc) => contacts.OrderBy(c => c.Gender).ToList(),
            (SortField.Gender, SortDirection.Desc) => contacts.OrderByDescending(c => c.Gender).ToList(),

            (SortField.Email, SortDirection.Asc) => contacts.OrderBy(c => c.Email).ToList(),
            (SortField.Email, SortDirection.Desc) => contacts.OrderByDescending(c => c.Email).ToList(),

            _ => contacts
        };
    }

    void ClearSort()
    {
        sortField = null;
        sortDirection = SortDirection.Asc;
        _ = Refresh();
    }

    async Task Refresh()
    {
        contacts = await LoadDirectoryAsync();
        ApplySort();
    }

    private async Task DeleteUserAsync(Guid id)
    {
        if (!canEdit) return;
        busy = true;
        try
        {
            await Api.DeleteAsync($"/api/users/{id}");
            await Refresh();
        }
        finally
        {
            busy = false;
        }
    }

    private async Task DeleteSharedContactAsync(int id)
    {
        if (!canEdit) return;
        busy = true;
        try
        {
            await Api.DeleteAsync($"/api/contacts/{id}");
            await Refresh();
        }
        finally
        {
            busy = false;
        }
    }

    private async Task<List<DirectoryContactResponse>> LoadDirectoryAsync()
    {
        var res = await Api.GetAsync<List<DirectoryContactResponse>>("/api/directory");
        return res ?? new();
    }

    enum SortField
    {
        Name,
        Phone,
        Gender,
        Email
    }

    enum SortDirection
    {
        Asc,
        Desc
    }
}
