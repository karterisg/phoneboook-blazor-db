@page "/view-contact/{Id:int}"
@using PhoneBookApp.Models
@inject NavigationManager Nav
@inject phonemanagement.Services.IContactsStore Store
@inject phonemanagement.Services.ClientAuthState Auth
@rendermode InteractiveServer

<PageTitle>Λεπτομέρειες επαφής</PageTitle>

@if (!authReady)
{
    <p class="text-muted">Φόρτωση…</p>
}
else if (contact == null)
{
    <div class="alert alert-warning border-0 shadow-sm">Η επαφή δεν βρέθηκε.</div>
}
else
{
    <div class="pb-page-header">
        <p class="pb-kicker">Προβολή</p>
        <h1>Κάρτα επαφής</h1>
    </div>

    <div class="pb-card" style="max-width: 32rem;">
        <div class="pb-card-body">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="pb-avatar" style="width:3.5rem;height:3.5rem;font-size:1.25rem;border-radius:14px;">@GetInitial(contact.Name)</div>
                <div>
                    <h2 class="h4 mb-1">@contact.Name</h2>
                    <span class="pb-gender-pill @GenderPillClass(contact.Gender)">@contact.Gender</span>
                </div>
            </div>
            <dl class="row mb-0 g-2">
                <dt class="col-sm-3 text-muted small">Τηλέφωνο</dt>
                <dd class="col-sm-9 mb-0">@contact.Phone</dd>
                <dt class="col-sm-3 text-muted small">Email</dt>
                <dd class="col-sm-9 mb-0">@contact.Email</dd>
            </dl>
        </div>
    </div>

    <div class="mt-3 d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-primary" @onclick="GoBack"><i class="bi bi-arrow-left me-1"></i>Πίσω στον κατάλογο</button>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Contact? contact;
    private bool authReady;

    private static string GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var t = name.Trim();
        return t.Length == 0 ? "?" : char.ToUpper(t[0]).ToString();
    }

    private static string GenderPillClass(string? gender) =>
        string.Equals(gender, "Female", StringComparison.OrdinalIgnoreCase) ? "pb-gender-pill--f" : "pb-gender-pill--m";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Auth.LoadAsync();
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        contact = await Store.GetByIdAsync(Id);
        authReady = true;
        await InvokeAsync(StateHasChanged);
    }

    void GoBack() => Nav.NavigateTo("/contacts");
}
