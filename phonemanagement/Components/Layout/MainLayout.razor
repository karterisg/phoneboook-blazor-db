@inherits LayoutComponentBase
@inject phonemanagement.Services.ClientAuthState Auth

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a class="text-decoration-none app-top-link" href="/about" title="About this app">About the app</a>
        </div>

        <article class="content px-3 px-md-4 app-main">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await Auth.LoadAsync();
    }
}
